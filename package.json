{
  "name": "aaradhya-enviro-website",
  "version": "2.0.0",
  "description": "Aaradhya Enviro - Environmental Consultancy Services Website",
  "scripts": {
    "dev": "npm run css:watch",
    "build": "npm run css:build && npm run js:minify",
    "css:watch": "node node_modules/tailwindcss/lib/cli.js -i ./assets/css/main-source.css -o ./assets/css/main.css --watch",
    "css:build": "node node_modules/tailwindcss/lib/cli.js -i ./assets/css/main-source.css -o ./assets/css/main.css --minify",
    "js:minify": "node node_modules/terser/bin/terser assets/js/main.js -o assets/js/main.min.js --compress --mangle",
    "optimize:images": "node scripts/optimize-images.js",
    "generate:sitemap": "node scripts/generate-sitemap.js"
  },
  "dependencies": {
    "jsdom": "^28.1.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.0.6",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "terser": "^5.36.0"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead",
    "not IE 11"
  ]
}
